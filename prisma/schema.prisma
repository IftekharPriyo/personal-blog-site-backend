generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  EDITOR
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id       String   @id @default(uuid())
  name     String
  email    String   @unique
  password String
  role     UserRole @default(EDITOR)

  posts BlogPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id   String @id @default(uuid())
  name String @unique
  slug String @unique

  posts BlogPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogPost {
  id         String     @id @default(uuid())
  title      String
  slug       String     @unique
  excerpt    String?
  content    String     @db.Text
  coverImage String?
  status     PostStatus @default(DRAFT)

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  travelCountryId String?
  travelCountry   TravelCountry? @relation(fields: [travelCountryId], references: [id])

  tags BlogPostTag[]

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Tag {
  id   String @id @default(uuid())
  name String @unique
  slug String @unique

  posts BlogPostTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogPostTag {
  postId String
  tagId  String

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

model TravelCountry {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  countryCode String?
  description String? @db.Text
  coverImage  String?

  cities TravelCity[]
  posts  BlogPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TravelCity {
  id   String @id @default(uuid())
  name String
  slug String

  countryId String
  country   TravelCountry @relation(fields: [countryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([countryId, slug])
}
